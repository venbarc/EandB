{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node node_modules/vite/bin/vite.js build",
        "dev": "node node_modules/vite/bin/vite.js",
        "test:e2e": "node node_modules/@playwright/test/cli.js test",
        "test:e2e:ui": "node node_modules/@playwright/test/cli.js test --ui",
        "test:e2e:headed": "node node_modules/@playwright/test/cli.js test --headed",
        "test:e2e:report": "node node_modules/@playwright/test/cli.js show-report e2e/report",
        "test:e2e:auth": "node node_modules/@playwright/test/cli.js test --project=auth-flows",
        "test:e2e:chrome": "node node_modules/@playwright/test/cli.js test --project=chromium",
        "playwright:install": "node node_modules/@playwright/test/cli.js install"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.2.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@inertiajs/react": "^2.3.15",
        "@playwright/test": "^1.49.0",
        "lucide-react": "^0.574.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
